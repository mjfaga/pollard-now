# PayPal donation thank-you email — required for /api/paypal/webhook.
# Copy to `.env.local` for local dev, and set the same keys in
# Vercel → Project → Settings → Environment Variables for production.
# Never commit real secrets; this file lists names only.

# --- PayPal (Dashboard → Apps & Credentials, then Webhooks) ---
PAYPAL_ENV=live                 # "live" in production, "sandbox" while testing
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=              # from the webhook you point at /api/paypal/webhook

# --- Email delivery (Resend; requires a verified sending domain) ---
RESEND_API_KEY=
DONATION_FROM_EMAIL="Pollard Now <donations@your-verified-domain>"

# --- Optional ---
DONATION_REPLY_TO=             # where donor replies should land, e.g. hello@your-domain
DONATION_NOTIFY_EMAIL=         # committee inbox: BCC'd on thank-yous + alerted if a donor email is missing
