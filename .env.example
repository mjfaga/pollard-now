# Mailchimp Marketing API — required for the subscribe form to deliver signups.
# Copy this file to `.env.local` and fill in the values. Never commit real secrets.

# Secret API key from Mailchimp → Account → Extras → API keys.
# Includes the datacenter suffix, e.g. xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-us4
MAILCHIMP_API_KEY=

# Target audience/list id. "Pollard Now Committee 2026" = 301eaebfa2
MAILCHIMP_AUDIENCE_ID=301eaebfa2

# Local testing only: set to 1 to skip all external form delivery (Mailchimp +
# the volunteer Google Form) so submitting any form shows its "thank you" panel
# without sending anything. Ignored in production builds. Leave unset normally.
FORMS_DRY_RUN=
